# ============================================================
# Capiva Cloud — variáveis de ambiente (exemplo)
# Copie para .env e ajuste. Usado pelo docker-compose e backend.
# ============================================================

# --- Banco do Control Plane (configurável por ambiente) ---
DATABASE_PROVIDER=postgresql            # postgresql | mysql | sqlite
DATABASE_URL=postgresql://capiva:capiva@localhost:5432/capiva?schema=public

# --- API ---
PORT=3000
NODE_ENV=development

# --- Auth ---
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_MS=604800000          # 7 dias
JWT_ISSUER=capiva-cloud
JWT_AUDIENCE=capiva-cloud-client
COOKIE_SECURE=false                     # true em produção (HTTPS)

# --- Cifragem de credenciais em repouso (AES-256-GCM, 32 bytes hex/base64) ---
ENCRYPTION_KEY=change-me-32-bytes-key-000000000000

# --- Storage S3 (backups/uploads) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=capiva
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# --- Frontend ---
VITE_API_URL=http://localhost:3000
