DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://capiva:capiva@localhost:5432/capiva?schema=public

PORT=3000
NODE_ENV=development

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_MS=604800000
JWT_ISSUER=capiva-cloud
JWT_AUDIENCE=capiva-cloud-client
COOKIE_SECURE=false

ENCRYPTION_KEY=change-me-32-bytes-key-000000000000

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=capiva
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
