// ============================================================
// Capiva Cloud — Prisma schema (FONTE DA VERDADE do banco)
//
// Banco configurável por ambiente via DATABASE_PROVIDER.
// Para trocar de provider, ajuste `provider` abaixo e DATABASE_URL.
// O schema evita tipos exclusivos de um único banco (compatível
// com PostgreSQL, MySQL e SQLite). Configs flexíveis usam Json/String.
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated/client"
}

datasource db {
  provider = "postgresql" // postgresql | mysql | sqlite
}

// ----------------------------- Identidade & Tenancy -----------------------------

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]
  sessions     Session[]

  @@map("users")
}

model Organization {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  memberships  Membership[]
  teams        Team[]
  environments Environment[]
  clusters     Cluster[]
  gitConns     GitConnection[]
  projects     Project[]
  tlsCertificates      TlsCertificate[]
  dockerRegistries     DockerRegistry[]
  storageProviders     StorageProvider[]
  invitations          Invitation[]
  apiKeys              ApiKey[]
  notificationChannels NotificationChannel[]

  @@map("organizations")
}

enum Role {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(DEVELOPER)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("memberships")
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("teams")
}

// ----------------------------- Auth / Sessões -----------------------------

model Session {
  id          String   @id @default(cuid())
  userId      String
  // hash SHA-256 do refresh token ATUAL (nunca o valor cru)
  tokenHash   String   @unique
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  // device / fingerprint para auditoria
  ip          String?
  userAgent   String?
  fingerprint String?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  event          String
  userId         String?
  apiKeyId       String?
  sessionId      String?
  targetType     String?
  targetId       String?
  detail         String?
  ip             String?
  userAgent      String?
  at             DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
  @@map("audit_logs")
}

// ----------------------------- Infraestrutura -----------------------------

enum ClusterProvisioner {
  MANUAL // registrado por kubeconfig/token (cluster já existe)
  SSH // a plataforma instala via SSH
  COPY_PASTE // usuário cola o comando; nó faz callback p/ auto-registro
}

enum NodeRole {
  CONTROL_PLANE
  WORKER
}

model Cluster {
  id               String             @id @default(cuid())
  organizationId   String
  name             String
  region           String?
  provisioner      ClusterProvisioner @default(MANUAL)
  // kubeconfig/service-account CIFRADO em repouso (AES-256-GCM). Pode ser nulo
  // enquanto o cluster é provisionado (SSH/copy-paste).
  kubeconfigCipher String?
  // Para join de nós (k3s): URL do server e node-token (cifrado).
  serverUrl        String?
  nodeTokenCipher  String?
  // Token de uso único para o callback de auto-registro (modo copy-paste).
  registrationToken String?           @unique
  status           String             @default("unknown")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environments     Environment[]
  nodes            ClusterNode[]
  tasks            ProvisioningTask[]

  @@map("clusters")
}

model ClusterNode {
  id                  String   @id @default(cuid())
  clusterId           String
  role                NodeRole @default(WORKER)
  host                String
  sshUser             String?
  sshPort             Int      @default(22)
  // chave/senha SSH CIFRADA em repouso
  sshCredentialCipher String?
  internalIp          String?
  status              String   @default("pending") // pending/provisioning/ready/draining/removed
  createdAt           DateTime @default(now())
  cluster             Cluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@map("cluster_nodes")
}

model ProvisioningTask {
  id         String    @id @default(cuid())
  clusterId  String
  nodeId     String?
  kind       String // install-server / join-worker / add-control-plane / remove-node
  status     String    @default("running") // running/success/failed
  log        String    @default("")
  createdAt  DateTime  @default(now())
  finishedAt DateTime?
  cluster    Cluster   @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@index([clusterId])
  @@map("provisioning_tasks")
}

enum EnvironmentKind {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

model Environment {
  id             String            @id @default(cuid())
  organizationId String
  clusterId      String?
  name           String
  kind           EnvironmentKind   @default(DEVELOPMENT)
  namespace      String
  createdAt      DateTime          @default(now())
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cluster        Cluster?          @relation(fields: [clusterId], references: [id])
  applications   Application[]
  databases      ManagedDatabase[]

  @@map("environments")
}

// ----------------------------- Git -----------------------------

enum GitProviderKind {
  GITHUB
  GITLAB
  GITEA
}

model GitConnection {
  id                String          @id @default(cuid())
  organizationId    String
  provider          GitProviderKind
  // token de acesso CIFRADO + segredo de webhook
  accessTokenCipher String
  webhookSecret     String
  accountLogin      String?
  baseUrl           String? // p/ Gitea/GitLab self-hosted
  createdAt         DateTime        @default(now())
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applications      Application[]

  @@map("git_connections")
}

model GitCommit {
  id          String       @id @default(cuid())
  sha         String
  authorName  String?
  authorEmail String?
  branch      String?
  message     String?
  pullRequest String?
  createdAt   DateTime     @default(now())
  deployments Deployment[]

  @@unique([sha, branch])
  @@map("git_commits")
}

// ----------------------------- Projetos & Aplicações -----------------------------

model Project {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  slug           String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applications   Application[]
  databases      ManagedDatabase[]
  workers        Worker[]
  cronJobs       CronJob[]

  @@unique([organizationId, slug])
  @@map("projects")
}

enum SourceKind {
  DOCKER_IMAGE
  GITHUB
  GITLAB
  GITEA
  DOCKER_COMPOSE
  NIXPACKS
  RAILPACK
  BUILDPACKS
  STATIC
}

enum RolloutStrategy {
  ROLLING
  BLUE_GREEN
  CANARY
}

enum ResourceProfileKind {
  NANO
  SMALL
  MEDIUM
  LARGE
  XLARGE
  CUSTOM
}

model Application {
  id              String              @id @default(cuid())
  projectId       String
  environmentId   String
  name            String
  source          SourceKind
  // configuração da origem (imagem, repo, dockerfile, branch...) — flexível
  sourceConfig    Json
  // tags (string[]) para filtros e relatórios
  tags            Json?
  gitConnectionId String?
  profile         ResourceProfileKind @default(SMALL)
  // requests/limits quando CUSTOM
  customResources Json?
  rolloutStrategy RolloutStrategy     @default(ROLLING)
  rolloutConfig   Json? // canary: tráfego inicial, incremento, intervalo, autoRollback
  port            Int?                @default(3000)
  // TLS por aplicação: lets_encrypt | uploaded(certId) | none
  tlsMode           TlsMode @default(LETS_ENCRYPT)
  tlsCertificateId  String?
  // registry privado opcional (gera imagePullSecret)
  registryId        String?
  // estado desejado x observado
  desiredStatus   String              @default("running")
  observedStatus  String              @default("pending")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment   Environment         @relation(fields: [environmentId], references: [id])
  gitConnection GitConnection?      @relation(fields: [gitConnectionId], references: [id])
  deployments   Deployment[]
  domains       Domain[]
  envVars       EnvVar[]
  scaling       ScalingPolicy?
  depsAsSource  ServiceDependency[] @relation("DepSource")
  depsAsTarget  ServiceDependency[] @relation("DepTarget")
  volumes       Volume[]
  uptimeChecks  UptimeCheck[]

  @@map("applications")
}

enum DeploymentStatus {
  QUEUED
  BUILDING
  PUSHING
  DEPLOYING
  HEALTHY
  FAILED
  ROLLED_BACK
}

model Deployment {
  id            String            @id @default(cuid())
  applicationId String
  commitId      String?
  version       String
  imageRef      String?
  strategy      RolloutStrategy   @default(ROLLING)
  status        DeploymentStatus  @default(QUEUED)
  progress      Int               @default(0)
  podCount      Int               @default(0)
  startedAt     DateTime          @default(now())
  finishedAt    DateTime?
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  commit        GitCommit?        @relation(fields: [commitId], references: [id])
  events        DeploymentEvent[]

  @@index([applicationId])
  @@map("deployments")
}

model DeploymentEvent {
  id           String     @id @default(cuid())
  deploymentId String
  label        String
  detail       String?
  at           DateTime   @default(now())
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId])
  @@map("deployment_events")
}

model Domain {
  id            String      @id @default(cuid())
  applicationId String
  host          String      @unique
  // certificado: lets_encrypt | uploaded | none
  tlsMode       String      @default("lets_encrypt")
  // quando uploaded, qual certificado da org usar (opcional)
  tlsCertificateId String?
  tlsStatus     String      @default("pending")
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("domains")
}

enum EnvVarSource {
  MANUAL
  INJECTED
}

model EnvVar {
  id            String       @id @default(cuid())
  applicationId String
  key           String
  // valor CIFRADO quando secret
  value         String
  secret        Boolean      @default(false)
  source        EnvVarSource @default(MANUAL)
  // se INJECTED, qual dependência originou (permite sobrescrita)
  overridden    Boolean      @default(false)
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, key])
  @@map("env_vars")
}

enum ScalingMetric {
  CPU
  MEMORY
  REQUESTS
}

model ScalingPolicy {
  id            String        @id @default(cuid())
  applicationId String        @unique
  minReplicas   Int           @default(2)
  maxReplicas   Int           @default(10)
  metric        ScalingMetric @default(CPU)
  target        Int           @default(70)
  application   Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("scaling_policies")
}

model ServiceDependency {
  id           String      @id @default(cuid())
  sourceId     String
  targetId     String
  // variáveis geradas/injetadas pela conexão (ex.: DATABASE_URL)
  injectedKeys Json?
  createdAt    DateTime    @default(now())
  source       Application @relation("DepSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target       Application @relation("DepTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@map("service_dependencies")
}

// ----------------------------- Serviços gerenciados -----------------------------

enum ManagedServiceKind {
  POSTGRESQL
  MYSQL
  REDIS
  RABBITMQ
  KAFKA
  MINIO
  ELASTICSEARCH
  CLICKHOUSE
}

enum ManagedSize {
  EXTRA_SMALL
  SMALL
  MEDIUM
  LARGE
}

model ManagedDatabase {
  id               String             @id @default(cuid())
  projectId        String
  environmentId    String
  name             String
  kind             ManagedServiceKind
  size             ManagedSize        @default(SMALL)
  highAvailability Boolean            @default(false)
  // credenciais geradas CIFRADAS, config do operator, etc.
  config           Json?
  observedStatus   String             @default("pending")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment      Environment        @relation(fields: [environmentId], references: [id])
  backups          Backup[]

  @@map("managed_databases")
}

model Worker {
  id             String              @id @default(cuid())
  projectId      String
  name           String
  source         SourceKind
  sourceConfig   Json
  profile        ResourceProfileKind @default(SMALL)
  replicas       Int                 @default(1)
  observedStatus String              @default("pending")
  createdAt      DateTime            @default(now())
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("workers")
}

model CronJob {
  id             String              @id @default(cuid())
  projectId      String
  name           String
  schedule       String // cron expression
  source         SourceKind
  sourceConfig   Json
  profile        ResourceProfileKind @default(NANO)
  observedStatus String              @default("pending")
  createdAt      DateTime            @default(now())
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("cron_jobs")
}

enum BackupKind {
  DATABASE
  VOLUME
}

model Backup {
  id                String           @id @default(cuid())
  kind              BackupKind       @default(DATABASE)
  databaseId        String?
  volumeId          String?
  storageProviderId String?
  status            String           @default("running")
  destination       String?
  sizeBytes         BigInt?
  startedAt         DateTime         @default(now())
  finishedAt        DateTime?
  database          ManagedDatabase? @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
  @@map("backups")
}

// ----------------------------- Fase 3.1/3.2 -----------------------------

enum VolumeAccessMode {
  RWO // ReadWriteOnce (1 nó)
  RWX // ReadWriteMany (todos os pods veem a mesma pasta) — via Longhorn
}

model Volume {
  id            String           @id @default(cuid())
  applicationId String
  name          String
  mountPath     String
  sizeGi        Int              @default(1)
  accessMode    VolumeAccessMode @default(RWO)
  createdAt     DateTime         @default(now())
  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("volumes")
}

enum TlsMode {
  LETS_ENCRYPT
  UPLOADED
  NONE
}

model TlsCertificate {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  // cert/key PEM cifrados em repouso
  certCipher     String
  keyCipher      String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("tls_certificates")
}

model DockerRegistry {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  url            String
  username       String       @default("")
  passwordCipher String       @default("")
  /** Registry de destino padrão para o push das imagens construídas (Kaniko). */
  isDefault      Boolean      @default(false)
  /** Registry sem TLS / HTTP (push com --insecure --skip-tls-verify). */
  insecure       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("docker_registries")
}

enum StorageType {
  S3
}

model StorageProvider {
  id                String       @id @default(cuid())
  organizationId    String
  name              String
  type              StorageType  @default(S3)
  endpoint          String
  bucket            String
  region            String?
  credentialsCipher String
  isDefault         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("storage_providers")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           Role         @default(DEVELOPER)
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("invitations")
}

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  // sha256 da chave; nunca guardamos o valor cru
  keyHash        String       @unique
  prefix         String
  role           Role         @default(DEVELOPER)
  scopes         Json?
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("api_keys")
}

enum NotificationType {
  DISCORD
  SLACK
  TELEGRAM
  TEAMS
  EMAIL
  RESEND
  LARK
  PUSH // Expo push notifications (app mobile)
  WEBHOOK // webhook genérico
}

model NotificationChannel {
  id             String           @id @default(cuid())
  organizationId String
  type           NotificationType
  name           String
  // config (webhook url, token, smtp...) cifrada
  configCipher   String
  events         Json
  enabled        Boolean          @default(true)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("notification_channels")
}

model UptimeCheck {
  id            String         @id @default(cuid())
  applicationId String
  url           String
  intervalSec   Int            @default(60)
  enabled       Boolean        @default(true)
  createdAt     DateTime       @default(now())
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  results       UptimeResult[]

  @@index([applicationId])
  @@map("uptime_checks")
}

model UptimeResult {
  id           String      @id @default(cuid())
  uptimeCheckId String
  ok           Boolean
  statusCode   Int?
  latencyMs    Int?
  at           DateTime    @default(now())
  check        UptimeCheck @relation(fields: [uptimeCheckId], references: [id], onDelete: Cascade)

  @@index([uptimeCheckId])
  @@map("uptime_results")
}
